  "components": {
    "parameters": {
      "IdPath": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "responses": {
      "BadRequestError": {
        "description": "Requisicao invalida",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "NotFoundError": {
        "description": "Nao encontrado",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "ValidationError": {
        "description": "Erro de validacao",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "ConflictError": {
        "description": "Conflito de dados",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      },
      "InternalError": {
        "description": "Erro interno",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "StatusOnlyResponse": {
        "type": "object",
        "properties": {
          "statusCode": { "type": "integer", "example": 200 }
        },
        "required": ["statusCode"]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "statusCode": { "type": "integer", "example": 422 },
          "error": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "example": "VALIDATION_ERROR" },
              "description": { "type": "string", "example": "Name is required" }
            },
            "required": ["type", "description"]
          }
        },
        "required": ["statusCode", "error"]
      },
      "Condominium": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "name": { "type": "string", "example": "Residencial Porto Seguro" },
          "zip_code": { "type": "string", "pattern": "^\\d{8}$", "example": "12345678" },
          "url": { "type": "string", "format": "uri", "example": "https://www.portoseguro.com.br" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "name", "zip_code", "url"]
      },
      "CondominiumInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "zip_code": { "type": "string", "pattern": "^\\d{8}$" },
          "url": { "type": "string", "format": "uri" }
        },
        "required": ["name", "zip_code", "url"]
      },
      "Unit": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "name": { "type": "string", "example": "101" },
          "square_meters": { "type": "number", "nullable": true, "example": 80.5 },
          "bedroom_count": { "type": "integer", "nullable": true, "example": 2 },
          "condominium_id": { "type": "integer", "example": 1 },
          "condominium": { "$ref": "#/components/schemas/Condominium" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "name", "condominium_id"]
      },
      "UnitInput": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "square_meters": { "type": "number", "minimum": 0.000001 },
          "bedroom_count": { "type": "integer", "minimum": 0 },
          "condominium_id": { "type": "integer", "minimum": 1 }
        },
        "required": ["name", "condominium_id"]
      },
      "Person": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "full_name": { "type": "string", "example": "Maria da Silva" },
          "cpf": { "type": "string", "pattern": "^\\d{11}$", "example": "12345678909" },
          "email": { "type": "string", "format": "email", "example": "maria@email.com" },
          "birth_date": { "type": "string", "format": "date", "example": "1990-05-10" },
          "created_by_condominium_id": { "type": "integer", "nullable": true, "example": 1 },
          "created_by_condominium": { "$ref": "#/components/schemas/Condominium" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "full_name", "cpf", "email", "birth_date"]
      },
      "PersonInput": {
        "type": "object",
        "properties": {
          "full_name": { "type": "string" },
          "cpf": { "type": "string", "description": "Aceita com ou sem mascara" },
          "email": { "type": "string", "format": "email" },
          "birth_date": { "type": "string", "format": "date" },
          "created_by_condominium_id": { "type": "integer", "minimum": 1 }
        },
        "required": ["full_name", "cpf", "email", "birth_date"]
      },
      "Supplier": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "legal_name": { "type": "string" },
          "trade_name": { "type": "string" },
          "cnpj": { "type": "string", "pattern": "^\\d{14}$" },
          "email": { "type": "string", "format": "email" },
          "zip_code": { "type": "string", "pattern": "^\\d{8}$" },
          "address": { "type": "string" },
          "category": {
            "type": "string",
            "enum": [
              "Manutenção predial",
              "Limpeza e conservação",
              "Segurança e portaria",
              "Elétrica e hidráulica",
              "Obras e reformas",
              "Administrativo e outros"
            ]
          },
          "people": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Person" }
          },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "legal_name", "trade_name", "cnpj", "email", "zip_code", "address", "category"]
      },
      "SupplierInput": {
        "type": "object",
        "properties": {
          "legal_name": { "type": "string" },
          "trade_name": { "type": "string" },
          "cnpj": { "type": "string", "description": "Aceita com ou sem mascara" },
          "email": { "type": "string", "format": "email" },
          "zip_code": { "type": "string", "pattern": "^\\d{5}-?\\d{3}$" },
          "address": { "type": "string" },
          "category": {
            "type": "string",
            "enum": [
              "Manutenção predial",
              "Limpeza e conservação",
              "Segurança e portaria",
              "Elétrica e hidráulica",
              "Obras e reformas",
              "Administrativo e outros"
            ]
          },
          "person_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "type": "integer", "minimum": 1 }
          }
